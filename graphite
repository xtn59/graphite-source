def skip_right_click(event):
	global _glb_vol,skip_right,_cur_inx,_sel_sng
	if _cur_inx + 1 < len(_sng_lst):
		_cur_inx += 1
		_sel_sng = _sng_lst[_cur_inx]
		play_this_song()
def skip_right_enter(event):
