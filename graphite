def filex(thing):
	global _fg, _bg, _fnt
	
	_conf_path = Path.home() / '.config' / 'graphite' / 'graphite.conf'
	_shdots = False
	_label_lst = []

	_dos2 = Toplevel(_dos)
	_dos2.geometry("450x350")
	_dos2.resizable(False,False)
	_dos2.config(bg=_bg)

#	Had issues with dir_label
#	_dos2.grab_set()

	_return = Label(_dos2, fg=_fg,bg=_bg,font=_fnt,text="<-",cursor='hand2')
	_return.place(x=5,y=5)
	_return.bind('<Enter>', lambda event: _return.config(fg='grey'))
	_return.bind('<Leave>', lambda event: _return.config(fg=_fg))
	_return.bind('<Button-1>', lambda event: retur())
	
	_ok = Label(_dos2, fg=_fg,bg=_bg,font=_fnt,text="ok",cursor='hand2')
	_ok.place(x=25,y=5)
	_ok.bind('<Enter>', lambda event: _ok.config(fg='grey'))
	_ok.bind('<Leave>', lambda event: _ok.config(fg=_fg))
	_ok.bind('<Button-1>', lambda event: end_file())	

	def end_file():
		_dos2.destroy()
	
	def retur():
		nonlocal thing
		thing = os.path.dirname(thing)
		shfiles()
	
	def shdots():
		nonlocal _shdots

		if _shdots == True:
			_shdots = False
		elif _shdots == False:
			_shdots = True

		shfiles()
	
	def shfiles():
		nonlocal _label_lst, _shdots, thing

		_dos2.title(f'{thing}')

		if _shdots == False:
			_file_lst = sorted([f for f in os.listdir(thing) if not f.startswith('.')])
		else:
			_file_lst = sorted([f for f in os.listdir(thing)])
			
		offset_y = 20
	
		if len(_label_lst) > 0:
			for i in _label_lst:
				i.destroy()
	
			_label_lst.clear()
	
		def change_path(path,file):
			nonlocal thing

			if os.path.isdir(os.path.join(thing, file)) == True:
				thing = path
				shfiles()
			else:
				print('not a directory')
	
		for f in _file_lst:
			_file_label = Label(_dos2, text=f,bg=_bg,fg=_fg,font=_fnt,cursor='hand2')
			_label_lst.append(_file_label)
		
		for i in _label_lst:
			i.place(x=10,y=(10 + offset_y))
			i.bind('<Enter>', lambda event, it=i: it.config(fg='grey'))
			i.bind('<Leave>', lambda event, it=i: it.config(fg=_fg))
			i.bind('<Button-1>', lambda event, it=i: change_path(os.path.join(thing, it.cget('text')), str(it.cget('text'))))

			_place_info = i.place_info()
			_dos2.geometry(f'450x{int(_place_info['y']) + 22}')

			offset_y += 15

		offset_y = 0
		_file_lst = []
	
	shfiles()
	_dos2.bind('<period>', lambda event: shdots())
	_dos.wait_window(_dos2)
	return thing

def get_files(button,playlist):
	global _sel_sng,_sng_lst,_cur_inx,_hvr,_pus,_ply,artist_label,file_extension,_sng_raw_nme,_art_nme,song_path,app_path,cover_w,cover_h,_music_user_directory,cover_path,_notifications

	if playlist == False:
		if button == 1:
			# As promised, peak of my creativity.
			path = filex(_music_user_directory)
		elif button == 0:
			path = os.getcwd()
		elif button == 5: 
			for i in _arg_lst:
				if i.startswith("--dir="):
					path = i.split("--dir=")[1]
					if path.startswith('~') == True:
						path = path.replace("~", f"{Path.home()}", 1)
	files = []
	files_covert = []

	if playlist == False:
		if path:
			files = sorted([f for f in os.listdir(path) if f.endswith(('.mp3','.wav','.ogg','.flac','.aac','.m4a','.alac'))])
			files_covert = [f for f in os.listdir(path) if f.lower().endswith(('.jpg','.png'))]
	else:
		#This will allow us to read the specific and absolute paths of a file from ~/.config/graphite/playlist.conf
		#Later in the production of graphite i will lean towards a program, or just graphite, that helps the user choose the songs
		#and write the paths to the playlist just like in cmus with "add {directory}"

		with open(playlist_path, 'r') as f:
			for line in f:
				lne = (str(line)).strip('\n')
				if lne.endswith(('.mp3','.wav','.ogg','.flac','.aac','.m4a','.alac')):
					files.append(lne)
				elif lne.endswith(('.jpg','.png')):
					files_covert.append(lne)

	if files:
		if playlist == False:
			_sng_lst = [os.path.join(path, f) for f in files]
		else:
			_sng_lst = files			
		_sel_sng = _sng_lst[_cur_inx]
		_sng_raw_nme, file_extension = os.path.splitext(os.path.basename(_sel_sng))
		pygame.mixer.music.stop()
		_hvr = False
		_pus = False
		_cur_inx = 0
	else:
		_sng_lst = []
		_sel_sng = None
		song_name.config(text='no audio :^(')
	if files_covert:
		covert_file = os.path.join(path, files_covert[0])
		cover_path = str(covert_file)
		try:
			cover = Image.open(covert_file)
			cover = cover.resize((cover_w, cover_h), Image.Resampling.LANCZOS)
			cover = ImageTk.PhotoImage(cover)

			cover_label.config(image=cover)
			cover_label.image = cover
		except Exception as e:
			pass
	else:
		cover_path = f'{_logo2_directory}'
		cover = Image.open(f'{_logo2_directory}')
		cover = cover.resize((cover_w, cover_h), Image.Resampling.LANCZOS)
		cover = ImageTk.PhotoImage(cover)

		cover_label.config(image=cover)
		cover_label.image = cover
	
	if len(_sng_lst) > 0:
		play_this_song()

	update_ply_info()

def play_this_song():
	global _pus, _ply, _cur_inx, file_extension, _sng_raw_nme, song_path, _notifications, cover_path
	if _sel_sng:
		pygame.mixer.music.load(_sel_sng)
		pygame.mixer.music.set_volume(float(_glb_vol))
		pygame.mixer.music.play()
		_pus = False
		_ply = True
		_sng_raw_nme, file_extension = os.path.splitext(str(os.path.basename(_sel_sng)))

		ttag = TinyTag.get(str(_sel_sng))
		_art_nme = ttag.artist
		artist_label.config(text=str(_art_nme.lower()))
		song_name.config(text=str(_sng_raw_nme.lower()))
		_dos.title(f'{_sng_raw_nme.lower()}')

	if _notifications == 1:
		subprocess.run(["notify-send", f"{_sng_raw_nme} - {_art_nme}", "-i", cover_path], shell=True)

def play_click(event=None):
	global _sel_sng, _pus, _ply, _art_nme
	if not _sel_sng:
		song_name.config(text='no files given')
		return
	else:
		play_this_song()
def play_button_(event=None):
	global song_name,_pus,_ply,_art_nme
	if _pus:
		pygame.mixer.music.unpause()
		play_button.config(fg=_fg)
		_pus = False
		_ply = True
	elif _ply:
		pygame.mixer.music.pause()
		_pus = True
		_ply = False
	else:
		play_click()

def vol_click(event):
	global _glb_vol,vol_button
	if _glb_vol < Decimal('1.00'):
		_glb_vol += Decimal('0.05')
		pygame.mixer.music.set_volume(float(_glb_vol))
		vol_button.config(text=str(_glb_vol))
def vol_dec(event):
	global _glb_vol,vol_button
	if _glb_vol > Decimal('0.00'):
		_glb_vol -= Decimal('0.05')
		pygame.mixer.music.set_volume(float(_glb_vol))
		vol_button.config(text=str(_glb_vol))
def vol_scroll(event):
	if event.delta > 0:
		vol_click(event)
	else:
		vol_dec(event)

def skip_left_click(event):
	global _glb_vol,skip_left,_cur_inx,_sel_sng
	if _cur_inx - 1 >= 0:
		_cur_inx -= 1
		_sel_sng = _sng_lst[_cur_inx]
		play_this_song()
def skip_left_enter(event):
	global _hvr
	_hvr = True
	skip_left.config(fg='grey')
def skip_left_leave(event):
	global _hvr
	_hvr = False
